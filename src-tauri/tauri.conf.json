{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Deck",
  "version": "0.1.0",
  "identifier": "com.pc.streamdeck-clone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stream Deck",
        "width": 1055,
        "height": 885,
        "minWidth": 1050,
        "minHeight": 880,
        "dragDropEnabled": false,
        "decorations": false,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0NDJEMjc4QUMxQ0MzOEMKUldTTXd4eXNlTkpDdElMWnBQc1E0SUkvakJ4bjNUcFZWSGdnN1RBVml5RmFWc0dKWkprNG1CRFYK",
      "endpoints": [
        
      ]
    }
  }
}
