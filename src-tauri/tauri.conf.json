{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Pad",
  "version": "0.1.9",
  "identifier": "com.antonis.streampad",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stream Pad",
        "width": 1055,
        "height": 885,
        "minWidth": 1050,
        "minHeight": 880,
        "dragDropEnabled": false,
        "decorations": false,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Antonis Georgosopoulos",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "uninstallerHeaderImage": "installer/nsis-uninstaller-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp",
        "startMenuFolder": "Stream Pad"
      },
      "wix": {
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwN0U4RTRCREE4OTcwNgpSV1FHbDZpOTVPZ0hCNEVlNk5QZkpBY3ZzbVhQVXJtTUlnQUIxVVdXWDNFVFZpbzRPSXJ6SkpWdQo=",
      "endpoints": [
        "https://github.com/Antonis-ge0/Stream-Deck/releases/latest/download/latest.json"
      ]
    }
  }
}
